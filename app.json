{
  "expo": {
    "name": "quizos",
    "slug": "quizos",
    "version": "1.0.0",
    "web": {
      "favicon": "./Assets/favicon.png"
    },
    "scheme": "your-app-scheme",
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router"
    ],
    "orientation": "portrait",
    "icon": "./Assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./Assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./Assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.quizos"
    }
  }
}
